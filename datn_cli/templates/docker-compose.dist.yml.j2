# Generated by datn-cli — KHÔNG sửa tay (chạy `datn config`/`datn update` để đổi).
# Compose dist: pull images từ Docker Hub, KHÔNG bind-mount, KHÔNG --reload.
services:
  agent-api:
    image: {{ backend_image }}:{{ image_tag }}
    container_name: datn-agent-api
    ports:
      - "5000:8000"
    command: uvicorn api:app --host 0.0.0.0 --port 8000
    environment:
      POSTGRES_HOST: postgres
      POSTGRES_PORT: "5432"
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: chat_history
      QDRANT_HOST: qdrant
      QDRANT_PORT: "6333"
      MINIO_HOST: minio
      MINIO_PORT: "9000"
      MINIO_ACCESS_KEY: minioadmin
      MINIO_SECRET_KEY: minioadmin
      STORAGE_BUCKET: documents
      COLLECTION_NAME: documents
      MCP_SERVER_URL: http://mcp-server:8000/sse
    env_file:
      - {{ env_file }}
{%- if needs_host_gateway %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{%- endif %}
    depends_on:
      postgres:
        condition: service_healthy
      qdrant:
        condition: service_started
      minio:
        condition: service_started
    restart: always

  mcp-server:
    image: {{ backend_image }}:{{ image_tag }}
    container_name: datn-mcp-server
    ports:
      - "8000:8000"
    command: python -m mcp_server.mcp_server
    environment:
      POSTGRES_HOST: postgres
      POSTGRES_PORT: "5432"
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: chat_history
      QDRANT_HOST: qdrant
      QDRANT_PORT: "6333"
      MINIO_HOST: minio
      MINIO_PORT: "9000"
      MINIO_ACCESS_KEY: minioadmin
      MINIO_SECRET_KEY: minioadmin
      STORAGE_BUCKET: documents
      COLLECTION_NAME: documents
    env_file:
      - {{ env_file }}
{%- if needs_host_gateway %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{%- endif %}
    depends_on:
      postgres:
        condition: service_healthy
    restart: always

  frontend:
    image: {{ frontend_image }}:{{ image_tag }}
    container_name: datn-frontend
    ports:
      - "5173:80"
    depends_on:
      - agent-api
    restart: always

  postgres:
    image: postgres:16-alpine
    container_name: datn-postgres
    ports:
      - "5432:5432"
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: chat_history
    volumes:
      - datn_postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5
    restart: always

  qdrant:
    image: qdrant/qdrant:v1.15.1
    container_name: datn-qdrant
    ports:
      - "6333:6333"
    volumes:
      - datn_qdrant_data:/qdrant/storage
    restart: always

  minio:
    image: quay.io/minio/minio
    container_name: datn-minio
    ports:
      - "9000:9000"
      - "9001:9001"
    environment:
      MINIO_ROOT_USER: minioadmin
      MINIO_ROOT_PASSWORD: minioadmin
    command: server /data --console-address ":9001"
    volumes:
      - datn_minio_data:/data
    restart: always

volumes:
  datn_postgres_data:
  datn_qdrant_data:
  datn_minio_data:
